# salus ai - sunucu çevre değişkenleri şablonu
PORT=5000

# veritabanı bağlantı adresi (postgresql)
VERITABANI_URL=postgresql://kullanici_adi:sifre@host:port/veritabanil_adi?sslmode=require

# jwt token güvenliği için gizli anahtar
JWT_GIZLI_ANAHTAR=buraya_guvenli_ve_rastgele_bir_anahtar_girin

# gemini api anahtarı (sohbet ve yapay zeka araçları için)
GEMINI_API_ANAHTARI=buraya_gemini_api_anahtarinizi_girin

# opsiyonel: redis sunucu adresi (bulunmuyorsa otomatik bellek-içi önbelleğe geçilir)
REDIS_URL=redis://127.0.0.1:6379
